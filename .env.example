# Server Configuration
PORT=3000
NODE_ENV=development

# LTI 1.1 Configuration (set these in D2L External Learning Tools)
# The consumer key and secret must match what is configured in D2L Brightspace
LTI_CONSUMER_KEY=ksu-discussion-tool
LTI_CONSUMER_SECRET=change-this-to-a-strong-secret

# GPTZero API Key (get from https://gptzero.me)
GPTZERO_API_KEY=your-gptzero-api-key

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ksu-discussion

# Session Configuration
SESSION_SECRET=change-this-to-a-random-string-in-production
